# Copie este arquivo para ".env" e preencha os valores.
# No Railway, o plugin MySQL injeta MYSQLHOST/MYSQLPORT/MYSQLUSER/MYSQLPASSWORD/MYSQLDATABASE
# automaticamente — essas variáveis DB_* abaixo são só para rodar localmente (docker-compose).

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=senha_local_dev
DB_NAME=academia

JWT_SECRET=troque-este-segredo-em-producao

PORT=3000
